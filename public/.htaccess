<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Keep real files and directories untouched
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback for client-side routes (/contact, /talent, etc.)
  RewriteRule ^ index.html [L]
</IfModule>
